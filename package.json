{
  "name": "osmforcities",
  "version": "1.12.0",
  "private": true,
  "scripts": {
    "dev": "COMMIT_HASH=$(git rev-parse HEAD 2>/dev/null || echo 'unknown') next dev",
    "dev:test": "NODE_ENV=test next dev",
    "build": "BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) COMMIT_HASH=$(git rev-parse HEAD 2>/dev/null || echo 'unknown') next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "fallow": "fallow dead-code",
    "db:sync": "tsx prisma/sync-templates.ts",
    "generate-icons": "tsx prisma/generate-icons.ts",
    "translate-todos": "tsx prisma/translate-todos.ts",
    "test:unit": "vitest",
    "test:playwright": "NODE_ENV=test playwright test",
    "test:playwright:ui": "NODE_ENV=test playwright test --ui",
    "prepare": "husky",
    "i18n:check": "i18n-check --locales messages --source en",
    "i18n:check:fix": "i18n-check --locales messages --source en --fix",
    "i18n:review": "tsx scripts/export-translations.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset version && git add .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --project=storybook",
    "test-storybook:ui": "vitest --project=storybook --ui",
    "test-storybook:coverage": "vitest --project=storybook --coverage"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@next/env": "^15.5.18",
    "@next/mdx": "^15.5.18",
    "@prisma/client": "^6.9.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.80.7",
    "@turf/bbox": "^7.2.0",
    "@turf/centroid": "^7.2.0",
    "@turf/simplify": "^7.3.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/geojson": "^7946.0.16",
    "@types/osmtogeojson": "^2.2.34",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-text": "^9.0.5",
    "js-yaml": "^4.2.0",
    "lucide-react": "^0.513.0",
    "maplibre-gl": "^5.6.0",
    "next": "15.5.18",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.9.1",
    "osmtogeojson": "3.0.0-beta.5",
    "postmark": "^4.0.5",
    "react": "^19.2.3",
    "react-aria-components": "^1.12.1",
    "react-dom": "^19.2.3",
    "react-map-gl": "^8.0.4",
    "react-stately": "^3.41.0",
    "tailwind-merge": "^3.3.0",
    "use-intl": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint/eslintrc": "^3",
    "@lingual/i18n-check": "^0.8.4",
    "@playwright/test": "^1.58.0",
    "@storybook/addon-a11y": "^10.4.3",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/addon-vitest": "^10.4.3",
    "@storybook/nextjs-vite": "^10.4.3",
    "@storybook/react": "^10.4.3",
    "@tailwindcss/postcss": "^4",
    "@types/html-to-text": "^9.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-storybook": "^10.4.3",
    "fallow": "^2.91.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "playwright": "^1.58.0",
    "prisma": "^6.11.1",
    "storybook": "^10.4.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "messages/*.json": [
      "i18n-check --locales messages --source en"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/sync-templates.ts"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": ">=0.8.4 <1.0.0",
      "@vitest/browser": ">=4.1.8 <5.0.0",
      "vitest": ">=4.1.8 <5.0.0",
      "rollup": ">=4.59.0 <5.0.0",
      "@eslint/plugin-kit": ">=0.3.4 <1.0.0",
      "axios": ">=1.15.1 <2.0.0",
      "icu-minify": ">=4.9.2 <5.0.0",
      "flatted": ">=3.4.2 <4.0.0",
      "tar": ">=7.5.11 <8.0.0",
      "undici": ">=7.24.0 <9.0.0",
      "yaml": ">=2.8.3 <3.0.0",
      "postcss": ">=8.5.10 <9.0.0",
      "protocol-buffers-schema": ">=3.6.1 <4.0.0",
      "ws": ">=8.20.1 <9.0.0",
      "mdast-util-to-hast": ">=13.2.1 <14.0.0"
    }
  }
}
