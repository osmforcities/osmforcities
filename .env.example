# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/osmforcities?schema=public"

# Authentication & Security
AUTH_SECRET="your-secret-key-change-this-in-production"
AUTH_URL="http://localhost:3000"
CRON_ROUTE_SECRET="your-cron-secret-key-here"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email Configuration (Postmark)
# For Production: Required for magic link authentication
# For Development: Optional (magic links printed to console if not configured)
POSTMARK_API_TOKEN="your-postmark-api-token"
POSTMARK_FROM_EMAIL="noreply@mail.osmforcities.org"

# Email Behavior Control
# EMAIL_DISABLE="true"                          # Disable all email sending

# Task Configuration
DATASET_UPDATE_LIMIT="1" # Number of datasets to update per cron job run

# Overpass API instance (defaults to VK Maps as it is a large OSM instance, use wisely)
# OVERPASS_API_URL="https://maps.mail.ru/osm/tools/overpass/api/interpreter"

# Optional: Custom User-Agent string (if not set, will auto-generate with app URL)
# OSM_USER_AGENT="OSM for Cities (+https://osmforcities.org)"

# Umami Analytics (optional)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=""  # Website ID from Umami admin
# NEXT_PUBLIC_UMAMI_URL=""         # e.g. https://analytics.osmforcities.org

# Map Tile Provider
# Configure the tile provider via environment variable
# Default: CartoDB Positron (light theme, raster tiles, no API key needed)
NEXT_PUBLIC_MAP_TILE_URL="https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png"

# Alternative providers (uncomment to use):
# CartoDB Dark Matter (dark theme): https://a.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}@2x.png
# OpenStreetMap: https://tile.openstreetmap.org/{z}/{x}/{y}.png
# OpenFreeMap (vector tiles, may block): https://tiles.openfreemap.org/styles/positron
